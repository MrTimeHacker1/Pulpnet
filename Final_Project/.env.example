# ──────────────────────────────────────────────────────────────────────────
# IITK Agentic RAG — environment configuration
# Copy to `.env` and adjust. All values have sane dev defaults in config.py;
# everything here is optional unless you are switching to prod backends.
# ──────────────────────────────────────────────────────────────────────────

# --- Data locations (relative to repo root) ---
DATA_DIR=data
COURSES_DIR=data/courses
ACADEMIC_DOCS_DIR=data/academic_documents
TIMETABLE_DIR=data/timetable

# --- Vector store (Qdrant) ---
# Dev default: embedded local-file mode (no server). Leave QDRANT_URL empty.
QDRANT_PATH=./qdrant_storage
QDRANT_COLLECTION=iitk_rag
# Prod: point at a running Qdrant server instead of local-file mode.
# QDRANT_URL=http://localhost:6333

# --- Relational DB ---
# Dev default: SQLite file. Swap to Postgres by setting DB_URL, e.g.:
# DB_URL=postgresql+psycopg://rag:rag@localhost:5432/iitk_rag
DB_URL=sqlite:///./rag.db

# --- Cache (Redis) ---
# Optional. If unreachable, an in-process fallback cache is used automatically.
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_THRESHOLD=0.95

# --- Models ---
EMBED_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
GENERATOR_MODEL=google/gemma-4-E4B-it
# Device for model inference: "auto", "cuda", "cuda:0", "cpu". "auto" picks the
# least-busy CUDA device (by free VRAM) or falls back to CPU.
MODEL_DEVICE=auto
EMBED_DIM=768

# --- Retrieval / agent tuning ---
RETRIEVE_TOP_K=20
RERANK_TOP_K=5
SUFFICIENCY_MIN_SCORE=0.2
MAX_RETRIES=2
GEN_MAX_NEW_TOKENS=512
GEN_TEMPERATURE=0.3

# --- Misc ---
LOG_LEVEL=INFO
# HF token is read from the standard huggingface-cli login cache; set here only to override.
# HF_TOKEN=
